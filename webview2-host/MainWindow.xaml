<Window x:Class="WebGPUHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="IRS WebGPU POC"
        Width="1280" Height="820"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- status bar -->
            <RowDefinition Height="*" />       <!-- webview -->
        </Grid.RowDefinitions>

        <!-- Status bar — shows cache state and model load progress -->
        <Border Grid.Row="0" Background="#155fa0" Padding="10 6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           x:Name="StatusText"
                           Foreground="White"
                           FontFamily="Consolas"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Text="Initialising WebView2…" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                    <TextBlock x:Name="CacheStatus"
                               Foreground="#a0c4ff"
                               FontFamily="Consolas"
                               FontSize="11"
                               VerticalAlignment="Center" />
                    <TextBlock Foreground="#a0c4ff"
                               FontFamily="Consolas"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Text="Shared UDF: %ProgramData%\WebGPURuntime" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- WebView2 fills the rest of the window -->
        <wv2:WebView2 Grid.Row="1"
                      x:Name="WebView"
                      NavigationCompleted="WebView_NavigationCompleted" />
    </Grid>
</Window>
